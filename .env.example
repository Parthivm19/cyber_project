# Flask Security Key
FLASK_SECRET_KEY=change_this_to_a_random_secure_string

# Database URL
DATABASE_URL=sqlite:///cinevault.db

# Gemini AI API Key (Get this from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Encryption Key for Fernet (Leave blank to auto-generate, or provide 32-byte base64 string)
ENCRYPTION_KEY=
